# ===========================================
# AquaFlora Stock Sync v4.0 - .gitignore
# ===========================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# Virtual Environment
venv/
.venv/
env/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# ===========================================
# Project Specific
# ===========================================

# Environment & Secrets
.env
.env.*
!.env.example

# Database
*.db
*.db-journal

# Runtime State
last_run_stats.json
data/scraper_progress.json
data/vision_cache.json
data/search_cache.json
data/upload_log.txt
data/missing_products_report.json

# Logs
logs/*
!logs/.gitkeep
*.log

# Data folders
data/output/*
!data/output/.gitkeep

data/input/*
!data/input/.gitkeep

data/images/*
!data/images/.gitkeep

data/reports/*
!data/reports/.gitkeep

# Old/temp folders
Correção Imagem/
data/.old/
scripts/.old/

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.orig

# Test/Coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Node.js
node_modules/
package-lock.json

# AI/Agent artifacts
.gemini/
.copilot/
.cursor/

# Linting/Type checking
.mypy_cache/
.ruff_cache/